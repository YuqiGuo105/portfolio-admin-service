# Copy to .env and fill in the real values before running docker compose
# Never commit .env to version control.

# ── Supabase / Postgres ──────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:<port>/<db>?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# ── Aiven OpenSearch ─────────────────────────────────────────────────────────
OPENSEARCH_HOST=os-xxxxx.a.aivencloud.com
OPENSEARCH_PORT=27099
OPENSEARCH_USERNAME=avnadmin
OPENSEARCH_PASSWORD=

# ── Kafka (leave blank for local Docker Kafka; fill for Aiven Kafka) ─────────
# KAFKA_BOOTSTRAP_SERVERS is overridden inside compose to kafka:9092
# Set the vars below only when pointing at an external broker:
# KAFKA_BOOTSTRAP_SERVERS=kafka-xxxx.a.aivencloud.com:26769
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.scram.ScramLoginModule required username="..." password="...";

# ── Admin service secrets ────────────────────────────────────────────────────
ADMIN_SECRET=
SUPABASE_JWT_SECRET=
ADMIN_ALLOWED_EMAILS=you@example.com
ALLOWED_ORIGINS=http://localhost:3000

# ── OpenAI (rag-indexer) ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Kafka topics (leave blank to use defaults) ────────────────────────────────
# KAFKA_TOPIC_SEARCH_INDEX=content.search.index.v1
# KAFKA_TOPIC_RAG_INDEX=content.rag.index.v1
# KAFKA_TOPIC_NOTIFICATION_ARTICLE=content.notification.article-updates.v1
# KAFKA_TOPIC_NOTIFICATION_FEATURE=content.notification.feature-updates.v1
# KAFKA_TOPIC_NOTIFICATION_JOBS=content.notification.job-updates.v1
