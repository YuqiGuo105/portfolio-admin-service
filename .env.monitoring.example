# Grafana Cloud credentials — get these from grafana.com → My Account → Grafana Cloud portal
# Stack → Prometheus → "Send Metrics" button → shows URL + user ID
# Stack → Loki → "Send Logs" button → shows URL + user ID
# API Key: create one at grafana.com → My Account → API Keys → Add key (MetricsPublisher role)

# ─── Grafana Cloud Prometheus ──────────────────────────────────────────────────
GRAFANA_PROMETHEUS_URL=https://prometheus-prod-xx-xxx.grafana.net/api/prom/push
GRAFANA_PROMETHEUS_USER=123456
GRAFANA_API_KEY=glc_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Grafana Cloud Loki ────────────────────────────────────────────────────────
GRAFANA_LOKI_URL=https://logs-prod-xx.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USER=123456

# ─── Service URLs ──────────────────────────────────────────────────────────────
# Local dev: use localhost ports
# Cloud Run: use full .run.app URLs (e.g., https://portfolio-notification-service-xxxxx.a.run.app)
NOTIFICATION_SERVICE_URL=localhost:8080
ADMIN_SERVICE_URL=localhost:8081
SEARCH_INDEXER_URL=localhost:8082
RAG_INDEXER_URL=localhost:8083
AGENT_SERVICE_URL=localhost:8090
MCP_GATEWAY_URL=localhost:8091
AGGREGATOR_SERVICE_URL=localhost:8093
ALERTS_SERVICE_URL=localhost:8094
